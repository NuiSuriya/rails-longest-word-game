<div class="container">
<h1>New game!</h1>
<ul>
  <div class="grid">
  <% @letters.each do |letter|%>
  <li><%= letter %></li>
  <% end  %>
  </div>
</ul>
<p>What is the longest wprd you can find?</p>
<form action="/score" method="post" data-turbo="false">
  <input type="text" name="word" placeholder="Type your guess here...">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="submit" class="btn btn-outline-success" value="Play!">
</form>
</div>
